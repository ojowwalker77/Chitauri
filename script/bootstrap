#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$repo_root"

command -v bun >/dev/null || { echo "TeaCode requires Bun 1.3.12." >&2; exit 1; }
command -v node >/dev/null || { echo "TeaCode requires Node 24." >&2; exit 1; }
bun install --frozen-lockfile "$@"
