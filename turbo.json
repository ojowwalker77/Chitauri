{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "PORT",
    "VITE_WS_URL",
    "VITE_DEV_SERVER_URL",
    "ELECTRON_RENDERER_PORT",
    "CHITAURI_HOME",
    "CHITAURI_STATE_NAMESPACE",
    "CHITAURI_DESKTOP_WS_URL",
    "CHITAURI_BROWSER_USE_PIPE_PATH",
    "CHITAURI_BROWSER_PERF",
    "CHITAURI_PROVIDER_RUNTIME_IDLE_STOP_MS",
    "CHITAURI_GROK_ACP_DEBUG",
    "CHITAURI_WEB_SOURCEMAP",
    "CHITAURI_SERVER_SOURCEMAP",
    "CHITAURI_DESKTOP_SOURCEMAP",
    "CHITAURI_MODE",
    "CHITAURI_PORT",
    "CHITAURI_HOST",
    "CHITAURI_NO_BROWSER",
    "CHITAURI_AUTH_TOKEN",
    "CHITAURI_LOG_WS_EVENTS",
    "CHITAURI_AUTO_BOOTSTRAP_PROJECT_FROM_CWD"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "dist-electron/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": [],
      "cache": false
    },
    "test": {
      "dependsOn": ["^build"],
      "cache": false,
      "outputs": []
    }
  }
}
