{
  "name": "@t3tools/monorepo",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*",
      "scripts"
    ],
    "catalog": {
      "effect": "file:../../vendor/effect/effect-8881a9b.tgz",
      "@effect/platform-node": "file:../../vendor/effect/effect-platform-node-8881a9b.tgz",
      "@effect/openapi-generator": "file:../../vendor/effect/effect-openapi-generator-8881a9b.tgz",
      "@effect/sql-sqlite-bun": "file:../../vendor/effect/effect-sql-sqlite-bun-8881a9b.tgz",
      "@effect/vitest": "file:../../vendor/effect/effect-vitest-8881a9b.tgz",
      "@effect/language-service": "0.75.1",
      "@types/bun": "^1.3.9",
      "@types/node": "^24.10.13",
      "tsdown": "^0.20.3",
      "typescript": "^5.7.3",
      "vitest": "^4.0.0"
    }
  },
  "type": "module",
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || true",
    "bootstrap": "./script/bootstrap",
    "check": "./script/check",
    "verify": "./script/verify",
    "release:preflight": "./script/release-preflight",
    "dev": "node scripts/dev-runner.ts dev",
    "dev:server": "node scripts/dev-runner.ts dev:server",
    "dev:web": "node scripts/dev-runner.ts dev:web",
    "dev:marketing": "turbo run dev --filter=@t3tools/marketing",
    "dev:desktop": "node scripts/dev-runner.ts dev:desktop",
    "electron": "bun run start:desktop",
    "electron:dev": "node scripts/dev-runner.ts dev:desktop --state-namespace userdata",
    "start": "turbo run start --filter=t3",
    "start:desktop": "turbo run start --filter=@t3tools/desktop",
    "start:marketing": "turbo run preview --filter=@t3tools/marketing",
    "build": "turbo run build",
    "build:marketing": "turbo run build --filter=@t3tools/marketing",
    "build:desktop": "turbo run build --filter=@t3tools/desktop --filter=t3",
    "typecheck": "turbo run typecheck",
    "lint": "oxlint --report-unused-disable-directives",
    "test": "turbo run test",
    "test:desktop-smoke": "turbo run smoke-test --filter=@t3tools/desktop",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "build:contracts": "turbo run build --filter=@t3tools/contracts",
    "dist:desktop:artifact": "bun scripts/build-desktop-artifact.ts",
    "dist:desktop:dmg": "bun scripts/build-desktop-artifact.ts --platform mac --target dmg",
    "dist:desktop:dmg:arm64": "bun scripts/build-desktop-artifact.ts --platform mac --target dmg --arch arm64",
    "dist:desktop:dmg:x64": "bun scripts/build-desktop-artifact.ts --platform mac --target dmg --arch x64",
    "dist:desktop:linux": "bun scripts/build-desktop-artifact.ts --platform linux --target AppImage --arch x64",
    "dist:desktop:win": "bun scripts/build-desktop-artifact.ts --platform win --target nsis --arch x64",
    "release:smoke": "node scripts/release-smoke.ts",
    "release:smoke:mac-update": "node scripts/smoke-mac-update-artifact.ts",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules scripts/node_modules apps/*/dist apps/*/dist-electron packages/*/dist .turbo apps/*/.turbo packages/*/.turbo"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "turbo": "^2.3.3",
    "vitest": "catalog:"
  },
  "overrides": {
    "@effect/platform-node-shared": "file:./vendor/effect/effect-platform-node-shared-8881a9b.tgz",
    "vite": "^8.0.0"
  },
  "engines": {
    "bun": "^1.3.9",
    "node": "^24.13.1"
  },
  "packageManager": "bun@1.3.12",
  "msw": {
    "workerDirectory": [
      "apps/web/public"
    ]
  }
}
